# Broker (paper trading recommended for MVP)
BROKER_PROVIDER=alpaca
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true

# Robinhood (live only — no paper trading; unofficial API; requires explicit ack)
# ROBINHOOD_USERNAME=your_robinhood_username
# ROBINHOOD_PASSWORD=your_robinhood_password
# ROBINHOOD_MFA_SECRET=your_totp_secret_if_enabled
# ROBINHOOD_SESSION_PATH=data/robinhood_session.pkl
# ROBINHOOD_LIVE_TRADING_ACK=false

# LLM: OpenAI primary with Gemini failover (recommended for backtests)
LLM_PROVIDER=openai
LLM_MODEL=financial
# Alias maps: openai financial/reasoning -> o4-mini; gemini financial/reasoning -> gemini-3.5-flash
LLM_FALLBACK_PROVIDER=gemini
LLM_FALLBACK_MODEL=financial
LLM_MAX_RETRIES=3

# Provider-specific API keys (primary + fallback when failover is enabled)
OPENAI_API_KEY=your_openai_api_key
GOOGLE_API_KEY=your_google_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key

# Service settings
TRADING_CYCLE_INTERVAL=30
LOG_LEVEL=INFO

# Live retrospection (Phase 4.5.5) — underperf detect after successful live cycles
# RETROSPECTION_WINDOW_DAYS=30
# RETROSPECTION_SPY_LAG_PP=0.05
# RETROSPECTION_HOLD_STREAK=3
# RETROSPECTION_COOLDOWN_DAYS=7

# Optional market signal providers (Phase 2)
FINNHUB_API_KEY=your_finnhub_api_key
FMP_API_KEY=your_fmp_api_key

# Local data directory (default: data/)
# DATA_DIR=data

# FMP file cache (default: enabled, data/cache/fmp/)
FMP_CACHE_ENABLED=true
# FMP_CACHE_DIR=data/cache/fmp
