{
  "family": "trading-agent-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::998982002518:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::998982002518:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "trading-agent",
      "image": "998982002518.dkr.ecr.us-west-2.amazonaws.com/trading-agent:latest",
      "essential": true,
      "environment": [
        { "name": "ALPACA_PAPER", "value": "true" },
        { "name": "LLM_PROVIDER", "value": "gemini" },
        { "name": "LLM_MODEL", "value": "financial" },
        { "name": "TRADING_CYCLE_INTERVAL", "value": "720" },
        { "name": "LOG_LEVEL", "value": "INFO" },
        { "name": "FMP_CACHE_ENABLED", "value": "true" }
      ],
      "secrets": [
        {
          "name": "ALPACA_API_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:998982002518:parameter/trading-agent/alpaca-api-key"
        },
        {
          "name": "ALPACA_SECRET_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:998982002518:parameter/trading-agent/alpaca-secret-key"
        },
        {
          "name": "GOOGLE_API_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:998982002518:parameter/trading-agent/google-api-key"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:998982002518:parameter/trading-agent/anthropic-api-key"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:998982002518:parameter/trading-agent/openai-api-key"
        },
        {
          "name": "HUGGINGFACE_API_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:998982002518:parameter/trading-agent/huggingface-api-key"
        },
        {
          "name": "FINNHUB_API_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:998982002518:parameter/trading-agent/finnhub-api-key"
        },
        {
          "name": "FMP_API_KEY",
          "valueFrom": "arn:aws:ssm:us-west-2:998982002518:parameter/trading-agent/fmp-api-key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/trading-agent",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
